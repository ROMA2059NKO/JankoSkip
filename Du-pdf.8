<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <title>Potraviny - DU08</title>
    <style>
     
        body {
            position: relative;
            height: 100vh;
            margin: 0;
        }

       
        img {
            position: absolute;
            width: 128px; 
        }

      
        .chlieb   { top: 5%;  left: 5%; }
        .mlieko   { top: 10%; left: 25%; }
        .maslo    { top: 20%; left: 40%; }
        .voda     { top: 30%; left: 55%; }
        .susienky { top: 40%; left: 70%; }
        .cokolada { top: 50%; left: 85%; }

        
        .hruska   { top: 5%;  right: 5%; }
        .ananas   { top: 15%; right: 25%; }
        .banan    { top: 35%; left: 30%; }
        .jablko   { top: 50%; left: 10%; }
    </style>
</head>
<body>

    
    <img src="images_du8/bread.jfif" class="chlieb" alt="Chlieb">
    <img src="images_du8/milch.jpg" class="mlieko" alt="Mlieko">
    <img src="images_du8/maslo.jpg" class="maslo" alt="Maslo">
    <img src="images_du8/voda.jpg" class="voda" alt="Voda">
    <img src="images_du8/susienka.jpg" class="susienky" alt="Sušienky">
    <img src="images_du8/čoklid.png" class="cokolada" alt="Čokoláda">

    
    <img src="images_du8/hruska.jpg" class="hruska" alt="Hruška">
    <img src="images_du8/anananananananalas.png" class="ananas" alt="Ananás">
    <img src="images_du8/bananananan.png" class="banan" alt="Banán">
    <img src="images_du8/apllleee.png" class="jablko" alt="Jablko">

</body>
</html>
