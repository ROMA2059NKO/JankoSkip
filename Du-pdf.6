    <!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <title>Super Video Player - DU06</title>
    <style>
       
        button {
            width: 64px;
            height: 64px;
            padding: 0;
            margin: 5px;
            cursor: pointer;
        }
        
        button img {
            width: 100%;
            height: 100%;
        }
    </style>
</head>
<body>

    <h1>Super Video Player</h1>

    
    <button><img src="images_du6/play-button.png" alt="Play"></button>
    <button><img src="images_du6/stop-button.png" alt="Stop"></button>
    <button><img src="images_du6/pause.png" alt="Pause"></button>
    
    <br>

    <button><img src="images_du6/zoom-in.png" alt="Zväčšiť"></button>
    <button><img src="images_du6/zoom-out.png" alt="Zmenšiť"></button>
    
    <br>

    <button><img src="images_du6/rotate-left.png" alt="Rotácia vľavo"></button>
    <button><img src="images_du6/rotate-right.png" alt="Rotácia vpravo"></button>
    
//obrazky asi nebudu fungovat na inom pc

</body>
</html>

