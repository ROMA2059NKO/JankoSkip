<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <title>JavaScript DU02</title>
</head>
<body>

    <script>
        // cisla
        var firstnumber = prompt("Zadaj 1. číslo:");
        var secondnumber = prompt("Zadaj 2. číslo:");
        var thirdnumber = prompt("Zadaj 3. číslo:");
        var fourthnumber = prompt("Zadaj 4. číslo:");
        var fifthnumber = prompt("Zadaj 5. číslo:");

        
        var sum = Number(firstnumber) + Number(secondnumber) + Number(thirdnumber) + Number(fourthnumber) + Number(fifthnumber);

        // nasobenie
        var multiplier = prompt("Zadaj číslo, ktorým chceš výsledok vynásobiť:");
        var multipliedresult = sum * Number(multiplier);

       // -23
        var subtractedresult = multipliedresult - 23;

        // :5
        var finalresult = subtractedresult / 5;

        
        alert("Konečný výsledok tvojich výpočtov je: " + finalresult);
    </script>

</body>
</html>
